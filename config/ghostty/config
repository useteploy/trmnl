background = 1a1a1a
background-opacity = 0.965
macos-titlebar-style = tabs
font-family = JetBrains Mono Nerd Font
font-size = 20
font-thicken = true
font-thicken-strength = 100

# Default window size
window-width = 200
window-height = 50

# Ultra-fine scroll control
# Try 0.5 or 0.1 for finer increments
scroll-multiplier = 0.5

# macOS-specific smooth scrolling
macos-option-as-alt = true
