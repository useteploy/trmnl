# ── Shell Functions ──────────────────────────────────────────────

# Python virtual environment shortcuts
function py-venv() {
  python3 -m venv venv
  source venv/bin/activate
}

function py-venv-activate() {
  source venv/bin/activate
}

# Node project setup
function node-setup() {
  pnpm init
  pnpm add -D typescript @types/node tsx
  echo '{"compilerOptions": {"target": "ES2020", "module": "ESNext"}, "include": ["src/**/*"]}' > tsconfig.json
  mkdir -p src
}

# Rust project setup
function rust-setup() {
  if [ -z "$1" ]; then
    echo "Usage: rust-setup <project-name>"
    return 1
  fi
  cargo new "$1"
  cd "$1"
  cargo add tokio
}

# Go project setup
function go-setup() {
  if [ -z "$1" ]; then
    echo "Usage: go-setup <module-name>"
    return 1
  fi
  go mod init "$1"
  mkdir -p cmd/app
  printf 'package main\n\nimport "fmt"\n\nfunc main() {\n\tfmt.Println("Hello")\n}\n' > cmd/app/main.go
}

# Quick profiling
function profile-py() {
  py-spy record -o profile.svg -- python3 "$1"
  echo "Profile saved to profile.svg"
}

# Database quick access
function sql-connect() {
  usql "$1"
}

# Docker quick shortcuts
function docker-clean() {
  docker system prune -f
  docker volume prune -f
}

function docker-stop-all() {
  local ids
  ids=$(docker ps -q)
  if [ -n "$ids" ]; then
    docker stop $ids
  else
    echo "No running containers"
  fi
}

# Kubernetes quick access
function k8s-pods() {
  kubectl get pods -A
}

# GitHub integration
function gh-pr-create-from-branch() {
  gh pr create --web --title "$(git rev-parse --abbrev-ref HEAD)" --body "Auto-created from $(git rev-parse --short HEAD)"
}

function gh-clone() {
  gh repo clone "$1"
}

# Shell history
function history-search() {
  atuin search "$1" 2>/dev/null || history | grep "$1"
}

