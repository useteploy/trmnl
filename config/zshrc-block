# ── Shell Functions ──────────────────────────────────────────────

# Launch tools from Neovim pane
function new-pane-left-with-neo() {
  zellij action new-pane -d left -c "nvim +Neotree"
}

function new-pane-right-with-yazi() {
  zellij action new-pane -d right -c "yazi"
}

function new-pane-down-with-terminal() {
  zellij action new-pane -d down
}

# Python virtual environment shortcuts
function py-venv() {
  python3 -m venv venv
  source venv/bin/activate
}

function py-venv-activate() {
  source venv/bin/activate
}

# Node project setup
function node-setup() {
  pnpm init -y
  pnpm add -D typescript @types/node tsx
  echo '{"compilerOptions": {"target": "ES2020", "module": "ESNext"}, "include": ["src/**/*"]}' > tsconfig.json
  mkdir -p src
}

# Rust project setup
function rust-setup() {
  cargo init --name "$1"
  cd "$1"
  cargo add tokio
}

# Go project setup
function go-setup() {
  go mod init "$1"
  mkdir -p cmd/app
  echo 'package main\n\nimport "fmt"\n\nfunc main() {\n\tfmt.Println("Hello")\n}' > cmd/app/main.go
}

# Quick profiling
function profile-py() {
  py-spy record -o profile.svg -- python3 "$1"
  echo "Profile saved to profile.svg"
}

function profile-node() {
  0x --help | head -5
  echo "Usage: 0x -- node script.js"
}

# Database quick access
function sql-connect() {
  usql "$1"
}

function sql-list-tables() {
  usql "$1" -c "\dt"
}

# Docker quick shortcuts
function docker-clean() {
  docker system prune -f
  docker volume prune -f
}

function docker-stop-all() {
  docker stop $(docker ps -q)
}

# Kubernetes quick access
function k8s-status() {
  kubectl cluster-info
}

function k8s-pods() {
  kubectl get pods -A
}

# Infrastructure as Code templates
function tf-init() {
  terraform init
  terraform fmt -recursive .
}

function tf-plan-save() {
  terraform plan -out=tfplan
  echo "Plan saved to tfplan"
}

# GitHub integration
function gh-pr-create-from-branch() {
  gh pr create --web --title "$(git rev-parse --abbrev-ref HEAD)" --body "Auto-created from $(git rev-parse --short HEAD)"
}

function gh-clone() {
  gh repo clone "$1"
}

# Shell history
function history-search() {
  atuin search "$1" 2>/dev/null || history | grep "$1"
}

# ── Performance Tuning ──────────────────────────────────────────

# Lazy load heavy commands
if command -v atuin &>/dev/null; then
  eval "$(atuin init zsh)" 2>/dev/null
fi

