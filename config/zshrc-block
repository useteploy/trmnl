# ── trmnl Terminal IDE ──────────────────────────────────────────

# ── Multiplexer Auto-Launch ──────────────────────────────────────
# Auto-start Zellij when opening a new shell (skip if already inside one)
if [ -z "$ZELLIJ" ]; then
  if command -v zellij &>/dev/null; then
    exec zellij
  elif command -v tmux &>/dev/null && [ -z "$TMUX" ]; then
    exec tmux
  fi
fi

# ── Core Tools Initialization ────────────────────────────────────

# Starship prompt
eval "$(starship init zsh)"

# Zoxide (smart cd)
eval "$(zoxide init zsh)"

# FZF fuzzy finder
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# Atuin shell history (loads only if installed)
if command -v atuin &>/dev/null; then
  eval "$(atuin init zsh)" 2>/dev/null
fi

# Direnv environment management (loads only if installed)
# eval "$(direnv hook zsh)"

# ── Core Aliases (always available) ──────────────────────────────

