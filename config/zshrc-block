alias ls='eza'
alias ll='eza -la'
alias lt='eza --tree'
alias cat='bat'

# Git shortcuts (Delta integration via gitconfig)
alias gd='git diff'
alias gds='git diff --staged'
alias gs='git status'

# Development shortcuts
alias vi='nvim'
alias neo='nvim +Neotree'
alias ya='yazi'
alias lg='lazygit'
alias tldr-update='tldr --update'

# System info
alias monitor='btop'

# Shell configuration
alias zshrc-edit='nvim ~/.zshrc'
alias zshrc-reload='source ~/.zshrc'

