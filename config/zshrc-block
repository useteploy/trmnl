command -v rga &>/dev/null && alias search-all='rga'

# Infrastructure (only if installed)
command -v terraform &>/dev/null && alias tf='terraform' && alias tfplan='terraform plan' && alias tfapply='terraform apply'
command -v ansible &>/dev/null && alias ans='ansible' && alias ansplaybook='ansible-playbook'
